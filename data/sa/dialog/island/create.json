{
  "type": "minecraft:confirmation",
  "title": {
    "text": "Create Island"
  },
  "body": [
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Warning!",
        "color": "dark_red"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Creating and/or joining an island is permanent and cannot be undone. So choose carefully."
      }
    }
  ],
  "inputs": [],
  "can_close_with_escape": true,
  "after_action": "close",
  "yes": {
    "label": {
      "text": "Start",
      "color": "green"
    },
    "action": {
      "type": "minecraft:run_command",
      "command": "trigger itrigger set 100"
    }
  },
  "no": {
    "label": {
      "text": "Cancel",
      "color": "red"
    },
    "action": {
      "type": "minecraft:show_dialog",
      "dialog": "sa:island/island_decide"
    }
  }
}