{
  "type": "minecraft:notice",
  "title": {
    "atlas": "minecraft:items",
    "sprite": "minecraft:item/fishing_rod",
    "extra": [
      {
        "text": " Fishing (Overview)",
        "color": "dark_aqua"
      }
    ]
  },
  "body": [
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Description",
        "color": "dark_aqua"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Fishing is one of the most important mechanics in Sky Attack. Many resources, mobs, and rare items can only be obtained through fishing. All loot pools have been specifically adapted for the Skyblock gameplay."
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Loot-Pools:",
        "color": "dark_aqua"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "• Fish (40%) – Standard-Fish\n• Junk (30%) – Ressources like Bamboo, Coal, Flint\n• Treasure (10%) – Rare Valuable Items\n• Creature (20%) – Spawns a Mob instead of an Item"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Creature Spawning:",
        "color": "dark_aqua"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "When fishing, a creature may spawn instead of an item. Which mob spawns depends on the biome. Some mobs can only be obtained through this method."
      }
    },
    {
      "type": "minecraft:item",
      "item": {
        "id": "minecraft:guardian_spawn_egg"
      },
      "description": {
        "text": "Guardian – Biom-dependant"
      }
    },
    {
      "type": "minecraft:item",
      "item": {
        "id": "minecraft:slime_spawn_egg"
      },
      "description": {
        "text": "Slime – Biom-dependant"
      }
    },
    {
      "type": "minecraft:item",
      "item": {
        "id": "minecraft:drowned_spawn_egg"
      },
      "description": {
        "text": "Drowned – Biom-dependant"
      }
    },
    {
      "type": "minecraft:item",
      "item": {
        "id": "minecraft:bogged_spawn_egg"
      },
      "description": {
        "text": "Bogged – Biom-dependant"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Fishing Pond:",
        "color": "dark_aqua"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "The hub features a special fishing pond that unlocks after completing the Fishing Pond Goal. It has its own biome and exclusive drops. (⚠ Coming Soon – will be completed in the near future)"
      }
    }
  ],
  "can_close_with_escape": true,
  "pause": false,
  "after_action": "close",
  "action": {
    "label": {
      "text": "Schließen"
    },
    "action": {
      "type": "minecraft:show_dialog",
      "dialog": "sa:menue/wiki"
    }
  }
}
