{
  "type": "minecraft:notice",
  "title": {
    "atlas": "minecraft:items",
    "sprite": "minecraft:item/fishing_rod",
    "extra": [
      {
        "text": " Fishing (Überblick)",
        "color": "dark_aqua"
      }
    ]
  },
  "body": [
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Beschreibung",
        "color": "dark_aqua"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Angeln ist eine der wichtigsten Mechaniken in Sky Attack. Viele Ressourcen, Mobs und seltene Items lassen sich ausschließlich durch Fischen erhalten. Alle Loot-Pools wurden speziell für das Skyblock-Gameplay angepasst."
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Loot-Pools:",
        "color": "dark_aqua"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "• Fish (40%) – Standard-Fische\n• Junk (30%) – Ressourcen wie Bambus, Kohle, Flint\n• Treasure (10%) – Seltene wertvolle Items\n• Creature (20%) – Spawnt einen Mob statt eines Items"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Creature Spawning:",
        "color": "dark_aqua"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Beim Angeln kann statt einem Item eine Kreatur erscheinen. Welcher Mob spawnt hängt vom Biom ab. Manche Mobs sind ausschließlich über diesen Weg erreichbar."
      }
    },
    {
      "type": "minecraft:item",
      "item": {
        "id": "minecraft:guardian_spawn_egg"
      },
      "description": {
        "text": "Guardian – Biom-abhängig"
      }
    },
    {
      "type": "minecraft:item",
      "item": {
        "id": "minecraft:slime_spawn_egg"
      },
      "description": {
        "text": "Slime – Biom-abhängig"
      }
    },
    {
      "type": "minecraft:item",
      "item": {
        "id": "minecraft:drowned_spawn_egg"
      },
      "description": {
        "text": "Drowned – Biom-abhängig"
      }
    },
    {
      "type": "minecraft:item",
      "item": {
        "id": "minecraft:bogged_spawn_egg"
      },
      "description": {
        "text": "Bogged – Biom-abhängig"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Fishing Pond:",
        "color": "dark_aqua"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Im Hub befindet sich ein spezieller Angelteich der nach dem Fishing Pond Goal freigeschaltet wird. Dort gibt es ein eigenes Biom und exklusive Drops. (⚠ Coming Soon – wird in naher Zukunft fertiggestellt)"
      }
    }
  ],
  "can_close_with_escape": true,
