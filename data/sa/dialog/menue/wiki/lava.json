    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Benötigt wird ein leerer Eimer und ein Magma Cube Spawn Egg."
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Crafting Rezept: ",
