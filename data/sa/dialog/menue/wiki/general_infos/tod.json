{
  "type": "minecraft:multi_action",
  "title": {
    "atlas": "minecraft:items",
    "sprite": "minecraft:item/bone",
    "extra": [
      {
        "text": " Beim Tod",
        "color": "red"
      }
    ]
  },
  "body": [
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "If you die in Sky Attack, the following happens:"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Inventory:",
        "color": "red"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "keepInventory is enabled – you will not lose your items. Your entire inventory will be retained."
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Minecraft XP-Level:",
        "color": "red"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "You lose half of your current Minecraft XP levels. The server divides your levels by 2 and resets them accordingly. A message in the chat will show you how many levels you have lost."
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Skill XP:",
        "color": "red"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Your Skill XP (Mining, Logging, Farming, Combat, Fishing) and Skill Levels will be fully retained upon death."
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Tip: Manage your Minecraft levels carefully, especially before dangerous actions in the Void or Nether.",
        "color": "gray",
        "italic": true
      }
    }
  ],
  "can_close_with_escape": true,
  "pause": false,
  "after_action": "close",
  "columns": 1,
  "actions": [
    {
      "label": {
        "text": "Back"
      },
      "action": {
        "type": "minecraft:show_dialog",
        "dialog": "sa:menue/wiki/general_infos"
      }
    }
  ]
}
