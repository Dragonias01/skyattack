{
  "type": "minecraft:multi_action",
  "title": {
    "atlas": "minecraft:items",
    "sprite": "minecraft:item/nether_star",
    "extra": [
      {
        "text": " Aufhol-System",
        "color": "aqua"
      }
    ]
  },
  "body": [
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Das Aufhol-System sorgt dafür, dass Spieler die hinter dem Server-Level liegen schneller aufholen können."
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Wie funktioniert es?",
        "color": "aqua"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Das System vergleicht dein Level in einem Skill mit dem höchsten Level das irgendein Spieler auf dem Server in diesem Skill hat. Daraus wird ein Prozentwert berechnet – deine Nähe zum Leader.\n \nJe weiter du hinter dem Leader liegst, desto mehr Bonus-XP bekommst du automatisch pro Aktion."
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Bonus-Tabelle:",
        "color": "aqua"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "0–20% des Leader-Levels → +700% XP\n21–40% → +500% XP\n41–60% → +300% XP\n61–80% → +200% XP\n81–90% → +100% XP\n91–100% → kein Bonus"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Beispiel:",
        "color": "aqua"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Der beste Mining-Spieler hat Level 100. Du hast Level 15. Das sind 15% des Leader-Levels → du bekommst +700% XP pro Stein. Statt 1 XP erhältst du also 8 XP pro Block."
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Das System gilt für alle 5 Skills separat. In einem Skill kann man weit hinten liegen und trotzdem in einem anderen vorne sein.",
        "color": "gray",
        "italic": true
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Hinweis:",
        "color": "aqua"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Der Bonus gilt zusätzlich zu aktiven Event-Boosts und Stack-XP durch den XP-Katalysator."
      }
    }
  ],
  "can_close_with_escape": true,
  "pause": false,
  "after_action": "close",
  "columns": 1,
  "actions": [
    {
      "label": {
        "text": "Zurück"
      },
      "action": {
        "type": "minecraft:show_dialog",
        "dialog": "sa:menue/wiki/general_infos"
      }
    }
  ]
}
