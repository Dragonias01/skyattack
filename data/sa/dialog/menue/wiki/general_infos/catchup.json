{
  "type": "minecraft:multi_action",
  "title": {
    "atlas": "minecraft:items",
    "sprite": "minecraft:item/nether_star",
    "extra": [
      {
        "text": "Catch-Up System",
        "color": "aqua"
      }
    ]
  },
  "body": [
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "The Catch-Up System ensures that players who are behind the server level can catch up faster."
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "How does it work?",
        "color": "aqua"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "The system compares your level in a skill with the highest level any player has in that skill on the server. This calculates a percentage – your proximity to the leader.\n \nThe further behind you are from the leader, the more bonus XP you automatically receive per action."
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Bonus Table:",
        "color": "aqua"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "0–20% of Leader Levels → +700% XP\n21–40% → +500% XP\n41–60% → +300% XP\n61–80% → +200% XP\n81–90% → +100% XP\n91–100% → no bonus"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Example:",
        "color": "aqua"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "The best Mining player has Level 100. You have Level 15. That's 15% of the Leader's Level → you get +700% XP per stone. Instead of 1 XP, you get 8 XP per block."
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "The system applies to all 5 skills separately. In one skill, you can be far behind and still be ahead in another.",
        "color": "gray",
        "italic": true
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Note:",
        "color": "aqua"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "The bonus applies additionally to active event boosts and stacked XP through the XP catalyst."
      }
    }
  ],
  "can_close_with_escape": true,
  "pause": false,
  "after_action": "close",
  "columns": 1,
  "actions": [
    {
      "label": {
        "text": "Back"
      },
      "action": {
        "type": "minecraft:show_dialog",
        "dialog": "sa:menue/wiki/general_infos"
      }
    }
  ]
}
