{
  "type": "minecraft:multi_action",
  "title": {
    "atlas": "minecraft:items",
    "sprite": "minecraft:item/clock_00",
    "extra": [
      {
        "text": " Hourly Events",
        "color": "gold"
      }
    ]
  },
  "body": [
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Every 60 minutes, a new server event automatically replaces the current one. The event applies to all players simultaneously."
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Display:",
        "color": "gold"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "The active event and the remaining countdown are displayed in the scoreboard (right in the image). You can see which event is currently running and how much time is left."
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Possible Events:",
        "color": "gold"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "⚡ Tickspeed x2",
        "color": "green"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "The randomTickSpeed is doubled to 30 (normal: 15). Plants grow twice as fast as in the normal state."
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "⚡ Tickspeed x4",
        "color": "green"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "The randomTickSpeed increases to 60 – four times the normal rate. Plants grow extremely fast. Use this event for massive farming."
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "⚔ Combat XP Boost",
        "color": "red"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "All players receive double Combat XP for the duration of the event."
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "🪓 Logging XP Boost",
        "color": "dark_green"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "All players receive double Logging XP for the duration of the event."
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "⛏ Mining XP Boost",
        "color": "gray"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "All players receive double Mining XP for the duration of the event."
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "🌾 Farming XP Boost",
        "color": "gold"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "All players receive double Farming XP for the duration of the event."
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "🎣 Fishing XP Boost",
        "color": "dark_aqua"
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "All players receive double Fishing XP for the duration of the event."
      }
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Note: The next event is randomly selected. You can therefore get the same event multiple times.",
        "color": "gray",
        "italic": true
      }
    }
  ],
  "can_close_with_escape": true,
  "pause": false,
  "after_action": "close",
  "columns": 1,
  "actions": [
    {
      "label": {
        "text": "Zurück"
      },
      "action": {
        "type": "minecraft:show_dialog",
        "dialog": "sa:menue/wiki/general_infos"
      }
    }
  ]
}
