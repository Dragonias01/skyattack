      {
        "text": " [Guide]",
        "color": "yellow"
      }
    ]
  },
  "body": [
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Welcome to SkyAttack!",
        "color": "gold",
        "bold": false
      },
      "width": 200
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "This datapack is a bit different. You spawn on an island and get to experience the Vanilla-Skyblock feeling all over again. Here you will find custom skill systems, new crafting systems, and a lot of new content. Much of it is hidden behind puzzles and requires a bit of brain power."
      },
      "width": 200
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": " "
      },
      "width": 200
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "The Menu",
        "color": "yellow",
        "bold": false
      },
      "width": 200
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "You'll receive a menu—it's located in the last slot of the hotbar. Don't place any items there; they'll be automatically removed!"
      },
      "width": 200
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "The menu will contain a Stats tab with a detailed overview of your statistics, as well as a complete in-game wiki. As you progress through the game, you'll be able to expand this wiki — more on that later."
      },
      "width": 200
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": " "
      },
      "width": 200
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "[WIP] Some texts and features are still in development and will be revised during the testing phase.",
        "color": "gray",
        "italic": true
      },
      "width": 200
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": " "
      },
      "width": 200
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "But let's get to creating the island—are you ready to get started?",
        "color": "green"
      },
      "width": 200
    }
  ],
  "inputs": [],
  "can_close_with_escape": true,
  "after_action": "wait_for_response",
  "action": {
    "label": {
      "text": "Let's get started!",
      "type": "text",
      "color": "dark_green"
    },
    "action": {
      "type": "minecraft:show_dialog",
